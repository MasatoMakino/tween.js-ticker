{
  "name": "@masatomakino/tween.js-ticker",
  "version": "0.8.2",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./esm/index.d.ts",
        "default": "./esm/index.js"
      },
      "default": {
        "types": "./esm/index.d.ts",
        "default": "./esm/index.js"
      }
    }
  },
  "types": "./esm/index.d.ts",
  "files": [
    "esm"
  ],
  "description": "Simple update loop module for tweenjs/tween.js.",
  "repository": {
    "type": "git",
    "url": "git+https://MasatoMakino@github.com/MasatoMakino/tween.js-ticker.git"
  },
  "author": "MasatoMakino <unagiinu.g@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "peerDependencies": {
    "@masatomakino/raf-ticker": "0.5.3 - 0.6.x",
    "@tweenjs/tween.js": "^25.0.0"
  },
  "devDependencies": {
    "@masatomakino/gulptask-demo-page": "^0.10.0",
    "@tweenjs/tween.js": "^25.0.0",
    "@vitest/coverage-istanbul": "4.1.0",
    "browser-sync": "^3.0.2",
    "jsdom": "^29.0.0",
    "prettier": "^3.3.3",
    "typedoc": "^0.28.0",
    "typescript": "^5.5.4",
    "vitest": "4.1.0"
  },
  "scripts": {
    "test": "vitest --run",
    "test:watch": "vitest",
    "coverage": "vitest --coverage --run",
    "pre-commit": "prettier --write --no-error-on-unmatched-pattern --ignore-unknown",
    "pre-push": "pnpm test",
    "start:dev": "pnpm run server & pnpm run watch:tsc & pnpm run watch:demo",
    "build": "pnpm run buildTS && pnpm run demo && pnpm run typedocs",
    "demo": "gulptask-demo-page",
    "buildTS": "tsc",
    "typedocs": "typedoc --out ./docs/api src/index.ts",
    "server": "browser-sync ./docs/demo -w --port 3000 --no-open",
    "watch:demo": "pnpm run demo -W",
    "watch:tsc": "tsc -W --incremental"
  },
  "bugs": {
    "url": "https://github.com/MasatoMakino/tween.js-ticker/issues"
  },
  "homepage": "https://github.com/MasatoMakino/tween.js-ticker#readme",
  "directories": {
    "doc": "docs",
    "lib": "esm"
  }
}
